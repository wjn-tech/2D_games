[gd_resource type="Resource" script_class="GuideSectionData" format=3 uid="uid://guide_inventory_section"]

[resource]
section_id = "inventory"
title = "背包与装备"
description = "物品管理和装备系统"
subsections = [SubResource("GuideSubsectionData_1"), SubResource("GuideSubsectionData_2")]

[sub_resource type="Resource" class_name="GuideSubsectionData" id="GuideSubsectionData_1"]
subsection_id = "open_inventory"
title = "打开背包"
content = "按下 [b]I[/b] 键打开背包窗口。\n
在背包窗口中，你可以查看和管理所有物品。\n
再次按 I 或点击窗口的关闭按钮来关闭背包。"
image = null

[sub_resource type="Resource" class_name="GuideSubsectionData" id="GuideSubsectionData_2"]
subsection_id = "equip_items"
title = "装备物品"
content = "从背包中拖动可装备的物品到快速栏位置。\n
快速栏位于屏幕底部（或其他位置，取决于UI设置）。\n
装备的物品可以通过按对应的快速键（1-9）来使用。"
image = null
