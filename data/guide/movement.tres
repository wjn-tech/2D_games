title = "键盘控制"
content = "使用 [b]WASD[/b] �?[color=yellow]方向键[/color] 来移动角色。\n
[b]A/D[/b]: 向左/右移动\n
[b]W/Up[/b]: 向上/前进\n
[b]S/Down[/b]: 向下/后退"
image = null

